# =========================
# Telegram bot token
# =========================
TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# =========================
# Premium / cookies mode
# =========================
# COOKIES_ENABLED:
#   true  - use cookies + JS runtime + bgutil POT provider flow (usually needed for YouTube Music Premium / fewer 403)
#   false - no cookies
COOKIES_ENABLED=false

# COOKIES_PATH:
#   Path to cookies.txt exported in Netscape format (what yt-dlp expects for --cookies).
#   Example:
#     COOKIES_PATH=/opt/bot/cookies.txt
COOKIES_PATH=

# RATE_LIMIT:
#   Per-user cooldown for PREMIUM downloads (only when COOKIES_ENABLED=true).
#   Value is in SECONDS. Example:
#     RATE_LIMIT=60   # one premium download per minute per user
#   Set 0 to disable:
#     RATE_LIMIT=0
RATE_LIMIT=0

# =========================
# What you MUST install/run when COOKIES_ENABLED=true
# =========================
# 1) Node.js (>=20) must be available in PATH (yt-dlp will use it as JS runtime)
# 2) Run the POT provider service (default port 4416):
#      docker run --name bgutil-provider -d --init -p 4416:4416 brainicism/bgutil-ytdlp-pot-provider:latest
# 3) Install the yt-dlp POT provider plugin (already in requirements.txt, but you can do it manually too):
#      pip install -U bgutil-ytdlp-pot-provider
#
# Notes:
# - This bot config sets yt-dlp options equivalent to:
#     --js-runtimes node --remote-components ejs:github --cookies <COOKIES_PATH> -f "bestaudio" --extract-audio --audio-format mp3 --audio-quality 0
